# Variáveis de ambiente — Cucos WC26
# Copiar para .env.local e preencher os valores.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# API-Football
API_FOOTBALL_KEY=

# Cron protection
CRON_SECRET=

# Web Push (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@cucos.pt

# Site URL (auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Analytics 4 (opcional)
# Criar propriedade em https://analytics.google.com → ID formato G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google AdSense (opcional — requer aprovação da conta)
# Painel AdSense → Conta → Informações da conta → ID do editor (ca-pub-...)
# Criar unidade de anúncio → ID do slot (número)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_SLOT_HOME=
